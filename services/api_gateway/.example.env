# ONLY EXAMPLE CONFIG

# LOGGING
LOG_FILE=api_gateway.log
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8080

MESSAGE_BROKER=rabbitmq

# RABBIT
RABBITMQ_URI=amqp://fluence_api_gateway_stl:rabbit_changeme@rabbitmq:5672/%2Ffluence_translation
RABBITMQ_EXCHANGE=fluence_translation.topic
RABBITMQ_ROUTING_KEY=to.in_gateway
RABBITMQ_OUTPUT_QUEUE=q.out_gateway
RABBITMQ_OUTPUT_PREFETCH_COUNT=32
RABBITMQ_RETRIES=3
